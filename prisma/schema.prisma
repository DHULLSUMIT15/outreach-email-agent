// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Investor {
  id              String     @id @default(uuid())
  name            String
  email           String
  firm            String
  stage           String
  notes           String
  tags            String     // Store as stringified JSON array
  lastContactedAt DateTime?
  status          String     @default("not_contacted")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  emails          Email[]
  followUps       FollowUp[]
}

model Email {
  id              String     @id @default(uuid())
  investorId      String
  subject         String
  body            String
  status          String     @default("draft")
  scheduledAt     DateTime?
  sentAt          DateTime?
  approved        Boolean    @default(false)
  createdAt       DateTime   @default(now())
  variant         Int?
  hookStyle       String?
  whyThisWorks    String?
  risk            String?

  investor        Investor   @relation(fields: [investorId], references: [id], onDelete: Cascade)
  followUps       FollowUp[]
}

model FollowUp {
  id              String     @id @default(uuid())
  emailId         String
  investorId      String
  sequenceNumber  Int
  frequency       String
  nextSendDate    DateTime
  stopped         Boolean    @default(false)
  subject         String
  body            String
  approved        Boolean    @default(false)
  sentAt          DateTime?
  createdAt       DateTime   @default(now())

  email           Email      @relation(fields: [emailId], references: [id], onDelete: Cascade)
  investor        Investor   @relation(fields: [investorId], references: [id], onDelete: Cascade)
}

model CompanyProfile {
  id                String   @id @default(uuid())
  founderName       String
  founderRole       String
  companyName       String
  oneLiner          String
  sector            String
  stage             String
  amountRaising     String
  roundStructure    String
  alreadyCommitted  String
  problem           String
  insight           String
  product           String
  differentiator    String
  revenue           String
  users             String
  growthRate        String
  loisWaitlist      String
  otherProof        String
  tamSam            String
  comparableExits   String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Activity {
  id              String   @id @default(uuid())
  type            String
  investorName    String
  description     String
  timestamp       DateTime @default(now())
}
